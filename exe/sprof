#!/usr/bin/env ruby
require "optparse"

output = "sprof.data"
frequency = 100
mode = "cpu"
verbose = false

parser = OptionParser.new do |opts|
  opts.banner = "Usage: sprof [options] [exec] command [args...]"

  opts.on("-o", "--output PATH", "Output file (default: sprof.data)") do |v|
    output = v
  end

  opts.on("-f", "--frequency HZ", Integer, "Sampling frequency in Hz (default: 100)") do |v|
    frequency = v
  end

  opts.on("-m", "--mode MODE", %w[cpu wall], "Profiling mode: cpu or wall (default: cpu)") do |v|
    mode = v
  end

  opts.on("-v", "--verbose", "Print sampling statistics to stderr") do
    verbose = true
  end

  opts.on("-h", "--help", "Show this help") do
    puts opts
    exit
  end
end

begin
  parser.order!(ARGV)
rescue OptionParser::InvalidOption => e
  $stderr.puts e.message
  $stderr.puts parser
  exit 1
end

# Skip "exec" subcommand if present
ARGV.shift if ARGV.first == "exec"

if ARGV.empty?
  $stderr.puts "No command specified."
  $stderr.puts parser
  exit 1
end

# Add lib dir to RUBYLIB so -rsprof can find the extension
lib_dir = File.expand_path("../lib", __dir__)
ENV["RUBYLIB"] = [lib_dir, ENV["RUBYLIB"]].compact.join(File::PATH_SEPARATOR)
ENV["RUBYOPT"] = "-rsprof #{ENV['RUBYOPT']}".strip
ENV["SPROF_ENABLED"] = "1"
ENV["SPROF_OUTPUT"] = output
ENV["SPROF_FREQUENCY"] = frequency.to_s
ENV["SPROF_MODE"] = mode
ENV["SPROF_VERBOSE"] = "1" if verbose

exec(*ARGV)
